---
/**
 * One score "dial": a ring that fills to where a value sits on its reference
 * scale (so a bare number is interpretable) and is tinted by the score's tone,
 * with the value centred and a label beneath. Pure presentational; data comes
 * from `buildScoreDials`.
 */
import { toneText, type ScoreDial } from '../lib/recipe';

interface Props {
  dial: ScoreDial;
}
const { dial } = Astro.props;

// r = 15.9155 → circumference ≈ 100, so the arc length is the fill percentage.
const dash = `${Math.round(dial.fill * 100)} 100`;
---

<div
  class="group relative flex flex-col items-center text-center gap-1.5 rounded-xl bg-card border border-line px-3 py-4 outline-none focus-visible:ring-2 focus-visible:ring-line"
  tabindex="0"
  aria-label={`${dial.label}: ${dial.value}. ${dial.blurb}`}
>
  <div class="relative h-16 w-16">
    <svg viewBox="0 0 36 36" class="absolute inset-0 h-full w-full -rotate-90" aria-hidden="true">
      <circle cx="18" cy="18" r="15.9155" fill="none" stroke="currentColor" stroke-width="2.5" class="text-line" />
      {
        dial.fill > 0 && (
          <circle
            cx="18"
            cy="18"
            r="15.9155"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-dasharray={dash}
            class={toneText[dial.tone]}
          />
        )
      }
    </svg>
    <div
      class:list={[
        'absolute inset-0 flex items-center justify-center font-display font-semibold text-ink',
        dial.value.length > 3 ? 'text-xl' : 'text-2xl',
      ]}
    >
      {dial.value}
    </div>
  </div>

  <div class="eyebrow !text-[0.62rem] !tracking-[0.14em] leading-tight text-ink-soft">{dial.label}</div>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute bottom-full left-1/2 z-30 mb-2 w-56 max-w-[78vw] -translate-x-1/2 rounded-lg bg-ink px-3 py-2 text-left font-ui text-[0.7rem] font-normal normal-case leading-snug tracking-normal text-paper opacity-0 shadow-lg transition-opacity duration-150 group-hover:opacity-100 group-focus-within:opacity-100"
  >
    {dial.blurb}
  </div>
</div>
