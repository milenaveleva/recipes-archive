---
/**
 * One facet group rendered as a row of toggle chips. The bundled script in
 * SearchFilter.astro wires clicks via the data attributes and reflects state in
 * `aria-pressed`; styling keys off that attribute so the chips need no JS to
 * look right and stay accessible.
 */
import type { FacetGroup } from '../lib/search';

interface Props {
  group: FacetGroup;
}
const { group } = Astro.props;
---

<div role="group" aria-label={group.label} class="flex flex-wrap items-center gap-1.5">
  <span class="eyebrow mr-1 shrink-0">{group.label}</span>
  {
    group.values.map((v) => (
      <button
        type="button"
        data-facet-group={group.key}
        data-facet-value={v.value}
        aria-pressed="false"
        aria-label={`${v.label}, ${v.count} ${v.count === 1 ? 'recipe' : 'recipes'}`}
        class="group/chip inline-flex items-baseline gap-1.5 rounded-full border border-line bg-card px-3 py-1 font-ui text-sm text-ink-soft transition-colors hover:border-spice hover:text-spice aria-pressed:border-spice aria-pressed:bg-spice aria-pressed:text-paper"
      >
        {v.label}
        <span aria-hidden="true" class="font-ui text-xs text-ink-faint tabular-nums group-aria-pressed/chip:text-paper/75">
          {v.count}
        </span>
      </button>
    ))
  }
</div>
