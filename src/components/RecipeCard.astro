---
import { Image } from 'astro:assets';
import type { Recipe } from '../lib/recipe';
import { recipeSlug, buildRecipeMeta, hasDisplayableScore } from '../lib/recipe';
import { withBase } from '../lib/url';
import Icon from './Icon.astro';
import ScoreMedallions from './ScoreMedallions.astro';

interface Props {
  recipe: Recipe;
  /** Stagger reveal index for the load animation. */
  index?: number;
}

const { recipe, index = 0 } = Astro.props;
const { data } = recipe;
const slug = recipeSlug(recipe);
const href = withBase(`/recipes/${slug}`);
// Cards omit Serves — it reads as noise next to the times at card scale.
const meta = buildRecipeMeta(data).filter((m) => m.icon !== 'serves');
const tags = data.tags.slice(0, 3);
const showScores = hasDisplayableScore(data.nutrition);
---

<a
  href={href}
  data-recipe-slug={slug}
  class="reveal group block no-underline"
  style={`animation-delay:${Math.min(index, 12) * 55}ms`}
>
  <article
    class="h-full overflow-hidden rounded-2xl border border-line bg-card transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_18px_40px_-24px_rgba(42,38,32,0.55)] group-hover:border-line-strong"
  >
    <div class="relative aspect-[4/3] overflow-hidden bg-paper-2">
      {
        data.image ? (
          <Image
            src={data.image}
            alt={data.imageAlt ?? data.title}
            widths={[300, 500, 700]}
            sizes="(max-width: 640px) 90vw, 360px"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.05]"
          />
        ) : data.imageUrl ? (
          <img
            src={data.imageUrl}
            alt={data.imageAlt ?? data.title}
            loading="lazy"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.05]"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-paper-2 to-paper">
            <span class="font-display text-5xl text-line-strong select-none">
              {data.title.slice(0, 1)}
            </span>
          </div>
        )
      }
      {
        data.category && (
          <span class="absolute left-3 top-3 rounded-full bg-paper/90 px-2.5 py-1 font-ui text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-ink-soft backdrop-blur-sm">
            {data.category}
          </span>
        )
      }
    </div>

    <div class="flex flex-col gap-3 p-4">
      <div>
        <h3
          class="font-display text-xl font-medium leading-snug text-ink transition-colors group-hover:text-spice"
          style="font-variation-settings:'SOFT' 30;"
        >
          {data.title}
        </h3>
        <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 font-ui text-xs text-ink-soft">
          {
            meta.map((m) => (
              <span class="inline-flex items-center gap-1">
                <Icon name={m.icon} class="h-3.5 w-3.5 shrink-0 text-ink-faint" />
                <span class="sr-only">{m.label}:</span>
                <span>{m.value}</span>
              </span>
            ))
          }
        </div>
      </div>

      {/* A sighted at-a-glance strip; its abbreviations would only bloat this
          card link's accessible name, and the fully-labelled medallions live on
          the recipe page — so hide it from assistive tech here. */}
      {showScores && (
        <div aria-hidden="true">
          <ScoreMedallions nutrition={data.nutrition} size="sm" />
        </div>
      )}

      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {tags.map((t) => (
              <span class="rounded-full border border-line px-2 py-0.5 font-ui text-[0.66rem] text-ink-soft">
                {t}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </article>
</a>
