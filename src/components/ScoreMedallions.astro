---
import type { CollectionEntry } from 'astro:content';
import { buildScoreDials, toneBg } from '../lib/recipe';
import ScoreDial from './ScoreDial.astro';

interface Props {
  nutrition: CollectionEntry<'recipes'>['data']['nutrition'];
  /** 'lg' for the detail page's nutrition rail (ring dials), 'sm' for a compact inline summary. */
  size?: 'lg' | 'sm';
}

const { nutrition, size = 'lg' } = Astro.props;
const dials = buildScoreDials(nutrition);
// The lg grid always shows all six medallion slots (an absent score reads as an
// em-dash ring); the compact strip drops absent scores so it never carries a
// dangling "GI —" chip.
const stripDials = dials.filter((d) => d.present);

// The six dials read as three families; labelling them lets the wall be scanned
// by group instead of as one undifferentiated block of numbers. Keys are typed to
// the dial-key union so a mistyped key is a compile error, not a silently dropped dial.
const groups: { label: string; keys: (typeof dials)[number]['key'][] }[] = [
  { label: 'Blood Sugar', keys: ['gi', 'gl'] },
  { label: 'Nutrition Quality', keys: ['nutri', 'balance'] },
  { label: 'Inflammation & Processing', keys: ['inflam', 'processing'] },
];

const abbrev = (d: (typeof dials)[number]) =>
  d.key === 'inflam'
    ? 'Inflam'
    : d.key === 'processing'
      ? 'Proc'
      : d.label
          .split(' ')
          .map((w) => w[0])
          .join('');
---

{
  size === 'lg' ? (
    <div>
      <div class="flex flex-col gap-4">
        {groups.map((g) => (
          <section>
            <h3 class="mb-1.5 font-ui text-[0.58rem] font-semibold uppercase tracking-[0.16em] text-ink-faint">
              {g.label}
            </h3>
            <div class="grid grid-cols-2 gap-3">
              {dials
                .filter((d) => g.keys.includes(d.key))
                .map((d, i) => (
                  <ScoreDial dial={d} align={i === 0 ? 'left' : 'right'} />
                ))}
            </div>
          </section>
        ))}
      </div>
      <p class="mt-3 font-ui text-[0.64rem] leading-snug text-ink-faint">
        Estimates for comparison — not medical or dietary advice.
      </p>
    </div>
  ) : (
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-ui text-[0.72rem] text-ink-soft">
      {stripDials.map((d) => (
        <span class="inline-flex items-center gap-1.5" title={`${d.label}: ${d.blurb}`}>
          <span class:list={['inline-block h-1.5 w-1.5 rounded-full', toneBg[d.tone]]} />
          <span class="font-semibold text-ink">{abbrev(d)}</span>
          <span>{d.value}</span>
        </span>
      ))}
    </div>
  )
}
