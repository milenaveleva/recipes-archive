---
/** Inline Lucide glyph (24×24, stroke = currentColor) drawn from ICONS (recipe
 * meta + search facet families), so every glyph comes from one source.
 * Decorative by default (aria-hidden); pair with an sr-only label for meaning. */
import { ICONS, type IconName } from '../lib/icons';

interface Props {
  name: IconName;
  class?: string;
}
const { name, class: className } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={ICONS[name]}
></svg>
