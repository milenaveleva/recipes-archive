---
import type { CollectionEntry } from 'astro:content';
import { formatIngredientAmount } from '../lib/recipe';

type Ingredient = CollectionEntry<'recipes'>['data']['ingredients'][number];

interface Props {
  ingredients: Ingredient[];
}
const { ingredients } = Astro.props;

// Preserve order while grouping by optional `group` header.
const groups: { name: string | null; items: Ingredient[] }[] = [];
for (const ing of ingredients) {
  const g = ing.group ?? null;
  let bucket = groups.find((x) => x.name === g);
  if (!bucket) groups.push((bucket = { name: g, items: [] }));
  bucket.items.push(ing);
}
---

<div class="flex flex-col gap-6">
  {
    groups.map((group) => (
      <div>
        {group.name && (
          <h3 class="eyebrow mb-3 !text-ink-soft">{group.name}</h3>
        )}
        <ul class="flex flex-col">
          {group.items.map((ing) => {
            const amt = formatIngredientAmount(ing);
            return (
              <li class="flex items-baseline gap-3 border-b border-line/70 py-2.5 last:border-0">
                <span class="min-w-[4.5rem] shrink-0 font-ui text-sm font-semibold tabular-nums text-spice">
                  {amt ?? ''}
                </span>
                <span class="font-body text-ink">
                  {ing.item}
                  {ing.note && <span class="text-ink-faint"> · {ing.note}</span>}
                  {amt == null && (
                    <span class="text-ink-faint"> {ing.raw}</span>
                  )}
                </span>
              </li>
            );
          })}
        </ul>
      </div>
    ))
  }
</div>
