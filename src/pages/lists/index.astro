---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import TermCloud from '../../components/TermCloud.astro';
import { visibleRecipes, allLists } from '../../lib/recipe';

const recipes = visibleRecipes(await getCollection('recipes'));
const lists = allLists(recipes);
---

<BaseLayout title="Lists">
  <PageHeader
    eyebrow="Browse"
    title="Lists"
    subtitle="Hand-picked collections — weeknight wins, batch-cook staples, and more."
  />
  <section class="mx-auto max-w-6xl px-5 sm:px-8 pb-8">
    {
      lists.length ? (
        <TermCloud terms={lists} basePath="/lists" />
      ) : (
        <p class="font-body text-ink-soft">No lists yet.</p>
      )
    }
  </section>
</BaseLayout>
