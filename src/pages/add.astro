---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import AddRecipe from '../components/add/AddRecipe.tsx';
---

<BaseLayout title="Add a recipe" description="Import a recipe by link or write one by hand.">
  <PageHeader
    eyebrow="In-app authoring"
    title="Add a recipe"
    subtitle="Paste a link to import a recipe, or write one by hand — ingredients are matched to USDA foods, converted to metric, and scored, then committed straight to the archive."
  />
  <section class="mx-auto max-w-3xl px-5 sm:px-8 pb-20">
    <AddRecipe client:only="react">
      <p slot="fallback" class="font-body text-ink-soft">Loading the editor…</p>
    </AddRecipe>
  </section>
</BaseLayout>
