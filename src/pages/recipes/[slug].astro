---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScoreMedallions from '../../components/ScoreMedallions.astro';
import IngredientList from '../../components/IngredientList.astro';
import NutritionPanel from '../../components/NutritionPanel.astro';
import JsonLd from '../../components/JsonLd.astro';
import {
  recipeSlug,
  formatDuration,
  extractSteps,
  slugifyTerm,
} from '../../lib/recipe';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const recipes = (await getCollection('recipes')).filter(
    (r) => import.meta.env.DEV || !r.data.draft,
  );
  return recipes.map((recipe) => ({
    params: { slug: recipeSlug(recipe) },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { data } = recipe;
const { Content } = await render(recipe);
const steps = extractSteps(recipe.body);

const meta = [
  formatDuration(data.prepTime) && { label: 'Prep', value: formatDuration(data.prepTime) },
  formatDuration(data.cookTime) && { label: 'Cook', value: formatDuration(data.cookTime) },
  formatDuration(data.totalTime) && { label: 'Total', value: formatDuration(data.totalTime) },
  { label: 'Serves', value: String(data.servings) },
  data.difficulty && { label: 'Difficulty', value: data.difficulty },
  data.cuisine && { label: 'Cuisine', value: data.cuisine },
].filter(Boolean) as { label: string; value: string }[];

const ogImage = data.image
  ? new URL(data.image.src, Astro.site).href
  : data.imageUrl;
const hasScores = !!data.nutrition?.glycemic || !!data.nutrition?.nutriScore || !!data.nutrition?.inflammation;
---

<BaseLayout title={data.title} description={data.description} ogImage={ogImage}>
  <JsonLd slot="head" recipe={recipe} steps={steps} />

  <article class="mx-auto max-w-5xl px-5 sm:px-8 pt-8 pb-4">
    <a
      href={withBase('/')}
      class="font-ui text-sm text-ink-soft no-underline transition-colors hover:text-spice"
    >
      ← All recipes
    </a>

    <header class="mt-6 reveal">
      {
        data.category && (
          <a
            href={withBase(`/categories/${slugifyTerm(data.category)}`)}
            class="eyebrow !text-spice no-underline"
          >
            {data.category}
          </a>
        )
      }
      <h1
        class="mt-3 font-display font-medium text-4xl sm:text-5xl text-ink"
        style="font-variation-settings:'SOFT' 50, 'WONK' 1;"
      >
        {data.title}
      </h1>
      {
        data.description && (
          <p class="mt-4 max-w-2xl font-body text-lg text-ink-soft">{data.description}</p>
        )
      }

      <div class="mt-5 flex flex-wrap items-center gap-x-6 gap-y-2">
        {
          meta.map((m) => (
            <div class="flex items-baseline gap-1.5">
              <span class="font-ui text-[0.66rem] uppercase tracking-[0.14em] text-ink-faint">
                {m.label}
              </span>
              <span class="font-ui text-sm font-semibold capitalize text-ink">{m.value}</span>
            </div>
          ))
        }
      </div>

      {
        data.source?.url && (
          <p class="mt-3 font-ui text-xs text-ink-faint">
            Adapted from{' '}
            <a
              href={data.source.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink-soft underline decoration-line-strong underline-offset-2 hover:text-spice"
            >
              {data.source.name ?? new URL(data.source.url).hostname.replace('www.', '')}
            </a>
          </p>
        )
      }
    </header>

    {
      (data.image || data.imageUrl) && (
        <figure class="mt-8 overflow-hidden rounded-2xl border border-line">
          {data.image ? (
            <Image
              src={data.image}
              alt={data.imageAlt ?? data.title}
              widths={[600, 900, 1280]}
              sizes="(max-width: 960px) 100vw, 960px"
              class="aspect-[16/9] w-full object-cover"
            />
          ) : (
            <img
              src={data.imageUrl}
              alt={data.imageAlt ?? data.title}
              class="aspect-[16/9] w-full object-cover"
            />
          )}
        </figure>
      )
    }

    {
      data.nutrition && (
        <section class="mt-8">
          <ScoreMedallions nutrition={data.nutrition} size="lg" />
        </section>
      )
    }
  </article>

  <div class="mx-auto max-w-5xl px-5 sm:px-8 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
      <aside class="lg:col-span-5 lg:sticky lg:top-24 lg:self-start flex flex-col gap-6">
        <div>
          <h2 class="font-display text-2xl text-ink mb-4">Ingredients</h2>
          <IngredientList ingredients={data.ingredients} />
        </div>
        {data.nutrition && <NutritionPanel nutrition={data.nutrition} />}
      </aside>

      <section class="lg:col-span-7">
        <h2 class="font-display text-2xl text-ink mb-4">Method</h2>
        <div class="recipe-prose">
          <Content />
        </div>

        {
          data.tags.length > 0 && (
            <div class="mt-10 flex flex-wrap gap-2">
              {data.tags.map((t) => (
                <a
                  href={withBase(`/tags/${slugifyTerm(t)}`)}
                  class="rounded-full border border-line bg-card px-3 py-1 font-ui text-xs text-ink-soft no-underline transition-colors hover:border-spice hover:text-spice"
                >
                  #{t}
                </a>
              ))}
            </div>
          )
        }

        {
          hasScores && (
            <p class="mt-8 rounded-lg border border-line bg-paper-2/60 px-4 py-3 font-ui text-xs leading-relaxed text-ink-faint">
              Glycemic index/load and the inflammation score are estimates derived
              from ingredient data and published references — useful for comparison,
              not a substitute for medical or dietary advice. The nutrition grade
              follows the Nutri-Score 2023 method.
            </p>
          )
        }
      </section>
    </div>
  </div>
</BaseLayout>
