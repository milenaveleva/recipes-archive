---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScoreMedallions from '../../components/ScoreMedallions.astro';
import IngredientList from '../../components/IngredientList.astro';
import NutritionPanel from '../../components/NutritionPanel.astro';
import JsonLd from '../../components/JsonLd.astro';
import RecipeActions from '../../components/RecipeActions.astro';
import PendingDetailView from '../../components/add/PendingDetailView.tsx';
import Icon from '../../components/Icon.astro';
import {
  recipeSlug,
  buildRecipeMeta,
  extractSteps,
  slugifyTerm,
  hasAnyScore,
} from '../../lib/recipe';
import { withBase } from '../../lib/url';
import { PENDING_KEY, PENDING_MAX_AGE_MS } from '../../core/pending';

export async function getStaticPaths() {
  const recipes = (await getCollection('recipes')).filter(
    (r) => import.meta.env.DEV || !r.data.draft,
  );
  return recipes.map((recipe) => ({
    params: { slug: recipeSlug(recipe) },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { data } = recipe;
const slug = recipeSlug(recipe);
const { Content } = await render(recipe);
const steps = extractSteps(recipe.body);

const meta = buildRecipeMeta(data);

const ogImage = data.image
  ? new URL(data.image.src, Astro.site).href
  : data.imageUrl;
const hasScores = hasAnyScore(data.nutrition);
// Show the per-serving panel (and its rail column) only when there's a value to
// show — mirrors NutritionPanel's own empty-state guard so an empty perServing
// never reserves a blank rail.
const hasNutritionPanel =
  !!data.nutrition?.perServing &&
  Object.values(data.nutrition.perServing).some((v) => v != null);
// The floating rail collects every nutrition figure — score medallions and the
// per-serving panel — so it appears whenever either has something to show.
const hasNutritionRail = hasScores || hasNutritionPanel;
// A serialized body opens with its own "## Method" heading; render a template
// one only for a body that carries none (e.g. a prose-only method with no
// numbered steps) so the page shows exactly one Method heading.
const bodyHasMethodHeading = /^##\s+Method\b/im.test(recipe.body ?? '');
---

<BaseLayout title={data.title} description={data.description} ogImage={ogImage} hideAddFab>
  <JsonLd slot="head" recipe={recipe} steps={steps} />
  <RecipeActions id={recipe.id} slug={slug} title={data.title} />

  {/* No-flash: if this page predates a still-pending edit of this recipe, hide
      the stale static content before paint; the island below renders the preview. */}
  <script is:inline define:vars={{ pendingKey: PENDING_KEY, maxAge: PENDING_MAX_AGE_MS, slug }}>
    try {
      const raw = localStorage.getItem(pendingKey);
      const list = raw ? JSON.parse(raw) : [];
      if (Array.isArray(list)) {
        const now = Date.now();
        const buildTime = Number(document.querySelector('meta[name="x-build-time"]')?.content) || 0;
        const m = list.find(
          (x) =>
            x &&
            x.slug === slug &&
            (x.kind === 'edit' || x.kind === 'create') &&
            typeof x.committedAt === 'number',
        );
        if (m && now - m.committedAt <= maxAge && buildTime < m.committedAt) {
          const style = document.createElement('style');
          style.id = 'pending-static-hide';
          style.textContent = '#recipe-static{display:none}';
          document.head.appendChild(style);
          // Safety net: the static recipe is the source of truth and must never
          // stay gated behind JS. If the preview island never confirms it took
          // over (bundle blocked / offline / render error), reveal the static
          // content so the page can't be left blank.
          setTimeout(function () {
            if (!window.__pendingPreviewReady) {
              const s = document.getElementById('pending-static-hide');
              if (s) s.remove();
            }
          }, 3000);
        }
      }
    } catch (e) {
      /* localStorage unavailable / corrupt — show the static content. */
    }
  </script>

  <PendingDetailView slug={slug} client:only="react" />

  <div id="recipe-static">
  <div
    class:list={[
      'mx-auto max-w-5xl px-5 sm:px-8 pt-8 pb-12',
      hasNutritionRail && 'xl:max-w-7xl',
    ]}
  >
    <a
      href={withBase('/')}
      class="font-ui text-sm text-ink-soft no-underline transition-colors hover:text-spice"
    >
      ← All recipes
    </a>

    <header class="mt-6 reveal">
      {
        data.category && (
          <a
            href={withBase(`/categories/${slugifyTerm(data.category)}`)}
            class="eyebrow !text-spice no-underline"
          >
            {data.category}
          </a>
        )
      }
      <h1
        class="mt-3 font-display font-medium text-4xl sm:text-5xl text-ink"
        style="font-variation-settings:'SOFT' 50, 'WONK' 1;"
      >
        {data.title}
      </h1>
      {
        data.description && (
          <p class="mt-4 max-w-2xl font-body text-lg text-ink-soft">{data.description}</p>
        )
      }

      <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-2">
        {
          meta.map((m) => (
            <div class="flex items-center gap-1.5">
              <Icon name={m.icon} class="h-4 w-4 shrink-0 text-ink-faint" />
              <span class="sr-only">{m.label}:</span>
              <span class="font-ui text-sm font-semibold text-ink">{m.value}</span>
            </div>
          ))
        }
      </div>

      {
        data.source?.url && (
          <p class="mt-3 font-ui text-xs text-ink-faint">
            Adapted from{' '}
            <a
              href={data.source.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink-soft underline decoration-line-strong underline-offset-2 hover:text-spice"
            >
              {data.source.name ?? new URL(data.source.url).hostname.replace('www.', '')}
            </a>
          </p>
        )
      }
    </header>

    {/* The hero image leads the main column; every nutrition figure — the score
        medallions and the per-serving panel — floats in a right-hand rail
        anchored level with the top of the image, pinned to the viewport once
        you scroll past the picture (`xl:sticky`). The rail spans every row so
        its inner card travels the full height of the recipe. Below xl it
        collapses into the single-column flow, right under the image. */}
    <div
      class:list={[
        'mt-8',
        hasNutritionRail &&
          'xl:grid xl:grid-cols-[minmax(0,1fr)_18rem] xl:grid-rows-[auto_auto] xl:gap-x-10',
      ]}
    >
      {
        (data.image || data.imageUrl) && (
          <figure class="overflow-hidden rounded-2xl border border-line xl:col-start-1 xl:row-start-1">
            {data.image ? (
              <Image
                src={data.image}
                alt={data.imageAlt ?? data.title}
                widths={[600, 900, 1280]}
                sizes="(min-width: 1280px) 888px, (min-width: 960px) 960px, 100vw"
                class="aspect-[16/9] w-full object-cover"
              />
            ) : (
              <img
                src={data.imageUrl}
                alt={data.imageAlt ?? data.title}
                class="aspect-[16/9] w-full object-cover"
              />
            )}
          </figure>
        )
      }

      <div class="mt-8 min-w-0 xl:col-start-1 xl:row-start-2">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
          <aside class="lg:col-span-5 lg:sticky lg:top-24 lg:self-start">
            <h2 class="font-display text-2xl text-ink mb-4">Ingredients</h2>
            <IngredientList ingredients={data.ingredients} />
          </aside>

          <section class="lg:col-span-7">
            {/* A serialized body opens with its own `## Method` heading (so the
                markdown file reads as a standalone document); .recipe-prose
                styles it to match the Ingredients header. Add a heading here
                only when the body carries none, so the page shows exactly one. */}
            {!bodyHasMethodHeading && (
              <h2 class="font-display text-2xl text-ink mb-4">Method</h2>
            )}
            <div class="recipe-prose">
              <Content />
            </div>

            {
              data.tags.length > 0 && (
                <div class="mt-10 flex flex-wrap gap-2">
                  {data.tags.map((t) => (
                    <a
                      href={withBase(`/tags/${slugifyTerm(t)}`)}
                      class="rounded-full border border-line bg-card px-3 py-1 font-ui text-xs text-ink-soft no-underline transition-colors hover:border-spice hover:text-spice"
                    >
                      #{t}
                    </a>
                  ))}
                </div>
              )
            }
          </section>
        </div>
      </div>

      {/* Scores render last in the DOM so that below xl — where the grid
          collapses to a single column — the recipe itself leads and the score
          wall follows it. At xl the explicit column/row placement lifts this
          aside back into the sticky right-hand rail level with the image. */}
      {
        hasNutritionRail && (
          <aside
            class="mt-8 max-w-md xl:mt-0 xl:max-w-none xl:col-start-2 xl:row-span-full"
            aria-labelledby="scores-heading"
          >
            <div class="flex flex-col gap-5 xl:sticky xl:top-24">
              <h2 id="scores-heading" class="sr-only">
                Nutrition scores &amp; facts
              </h2>
              {hasScores && <ScoreMedallions nutrition={data.nutrition} size="lg" />}
              {hasNutritionPanel && <NutritionPanel nutrition={data.nutrition} />}
            </div>
          </aside>
        )
      }
    </div>
  </div>
  </div>
</BaseLayout>
