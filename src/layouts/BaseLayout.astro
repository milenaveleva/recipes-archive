---
import '../styles/global.css';
import { withBase } from '../lib/url';
import AuthButton from '../components/AuthButton.astro';

interface Props {
  title?: string;
  description?: string;
  /** Absolute or already-based URL for social preview image. */
  ogImage?: string;
}

const {
  title,
  description = 'A personal archive of recipes — imported or hand-written, stored in uniform metric, with macros, glycemic index & load, inflammation and nutrition scores.',
  ogImage,
} = Astro.props;

const siteName = 'mili’s hedonistic cookbook';
const fullTitle = title ? `${title} — ${siteName}` : siteName;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// The landing page is the whole app — tags, categories and lists are filtered
// in place there, so the header carries no section nav, only sign-in.
const here = Astro.url.pathname.replace(/\/$/, '');
const onAddPage = here === withBase('/add').replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-line bg-paper/80 backdrop-blur-sm sticky top-0 z-40">
      <div class="mx-auto max-w-6xl px-5 sm:px-8">
        <div class="flex items-center justify-between gap-6 py-4">
          <a href={withBase('/')} class="group flex items-baseline gap-2.5 no-underline">
            <span
              class="font-display text-2xl sm:text-[1.7rem] font-medium tracking-tight text-ink"
              style="font-variation-settings:'SOFT' 40, 'WONK' 1;"
            >
              mili’s <s class="decoration-spice decoration-2">hedonistic</s> cookbook
            </span>
            <span
              class="hidden sm:inline-block h-2 w-2 rounded-full bg-spice transition-transform group-hover:scale-150"
            ></span>
          </a>
          <AuthButton />
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-20 border-t border-line">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-10 font-ui text-xs text-ink-faint flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
        <p>
          mili’s <s class="decoration-spice">hedonistic</s> cookbook — recipes stored as uniform metric markdown.
        </p>
        <p class="max-w-md">
          Nutrition, glycemic & inflammation figures are estimates for guidance
          only, not medical or dietary advice.
        </p>
      </div>
    </footer>

    {
      !onAddPage && (
        <a
          href={withBase('/add')}
          aria-label="Add a recipe"
          class="group fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-ink text-paper no-underline shadow-xl shadow-ink/25 ring-1 ring-ink/10 transition-[transform,background-color] duration-200 hover:scale-110 hover:bg-spice active:scale-95 sm:bottom-8 sm:right-8"
        >
          <span class="pointer-events-none absolute right-full mr-3 hidden whitespace-nowrap rounded-full bg-ink px-3 py-1.5 font-ui text-xs text-paper opacity-0 shadow-md transition-opacity duration-200 group-hover:opacity-100 sm:block">
            Add a recipe
          </span>
          <svg
            viewBox="0 0 24 24"
            width="24"
            height="24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
        </a>
      )
    }
  </body>
</html>
