---
import '../styles/global.css';
import { withBase } from '../lib/url';
import AuthButton from '../components/AuthButton.astro';
import Fab from '../components/Fab.astro';
import { PENDING_KEY, PENDING_MAX_AGE_MS } from '../core/pending';

interface Props {
  title?: string;
  description?: string;
  /** Absolute or already-based URL for social preview image. */
  ogImage?: string;
  /** Suppress the global Add (+) FAB — recipe pages render their own actions. */
  hideAddFab?: boolean;
}

const {
  title,
  description = 'A personal archive of recipes — imported or hand-written, stored in uniform metric, with macros, glycemic index & load, inflammation and nutrition scores.',
  ogImage,
  hideAddFab = false,
} = Astro.props;

const siteName = 'mili’s hedonistic longevity cookbook';
const fullTitle = title ? `${title} — ${siteName}` : siteName;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// The landing page is the whole app — tags, categories and lists are filtered
// in place there, so the header carries no section nav, only sign-in.
const here = Astro.url.pathname.replace(/\/$/, '');
const onAddPage = here === withBase('/add').replace(/\/$/, '');

// Wall-clock moment this page was built. The optimistic overlay (src/core/pending.ts)
// compares it against a mutation's commit time to know when the rebuild caught up.
const buildTime = Date.now();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="x-build-time" content={String(buildTime)} />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <slot name="head" />
    <script is:inline define:vars={{ pendingKey: PENDING_KEY, maxAge: PENDING_MAX_AGE_MS }}>
      // No-flash: before the grid paints, hide any card whose recipe has a fresh
      // pending delete (the overlay script then removes it for good). An inline
      // script can't import, so it reuses the shared key + max-age passed in.
      // The age guard mirrors prunePending so a failed build can't keep a still-
      // live card hidden forever.
      try {
        const raw = localStorage.getItem(pendingKey);
        const list = raw ? JSON.parse(raw) : [];
        if (Array.isArray(list)) {
          const now = Date.now();
          const slugs = list
            .filter(
              (m) =>
                m &&
                m.kind === 'delete' &&
                typeof m.slug === 'string' &&
                typeof m.committedAt === 'number' &&
                now - m.committedAt <= maxAge,
            )
            .map((m) => m.slug);
          if (slugs.length) {
            const esc = (s) =>
              window.CSS && CSS.escape ? CSS.escape(s) : String(s).replace(/["\\]/g, '\\$&');
            const sel = slugs.map((s) => `[data-recipe-slug="${esc(s)}"]`).join(',');
            const style = document.createElement('style');
            style.textContent = sel + '{display:none !important}';
            document.head.appendChild(style);
          }
        }
      } catch (e) {
        /* localStorage unavailable / corrupt — nothing to hide. */
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-line bg-paper/80 backdrop-blur-sm sticky top-0 z-40">
      <div class="mx-auto max-w-6xl px-5 sm:px-8">
        <div class="flex items-center justify-between gap-6 py-4">
          <a href={withBase('/')} class="group flex items-baseline gap-2.5 no-underline">
            <span
              class="font-display text-2xl sm:text-[1.7rem] font-medium tracking-tight text-ink"
              style="font-variation-settings:'SOFT' 40, 'WONK' 1;"
            >
              mili’s <s class="decoration-spice decoration-2">hedonistic</s> longevity cookbook
            </span>
            <span
              class="hidden sm:inline-block h-2 w-2 rounded-full bg-spice transition-transform group-hover:scale-150"
            ></span>
          </a>
          <AuthButton />
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-20 border-t border-line">
      <div class="mx-auto max-w-6xl px-5 sm:px-8 py-10 font-ui text-xs text-ink-faint flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
        <p>
          mili’s <s class="decoration-spice">hedonistic</s> longevity cookbook
        </p>
      </div>
    </footer>

    {
      !onAddPage && !hideAddFab && (
        <div data-auth-only class="fixed bottom-6 right-6 z-50 hidden sm:bottom-8 sm:right-8">
          <Fab href={withBase('/add')} label="Add a recipe">
            <svg
              viewBox="0 0 24 24"
              width="24"
              height="24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
          </Fab>
        </div>
      )
    }

    <script>
      // Reveal "add a recipe" affordances (the global + FAB, the empty-shelf
      // CTA) only to a signed-in user — the one who can commit. Mirrors the
      // Edit/Delete reveal on recipe pages via auth.ts's onSession, so content
      // pages stay React-free. Marked elements start hidden, so a signed-out
      // visitor never sees a button they can't use.
      import { onSession } from '../components/add/auth';

      const gated = document.querySelectorAll<HTMLElement>('[data-auth-only]');
      if (gated.length) {
        onSession((session) =>
          gated.forEach((el) => el.classList.toggle('hidden', !session)),
        );
      }
    </script>
  </body>
</html>
